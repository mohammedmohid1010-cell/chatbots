# ─────────────────────────────────────────────────────────────
#  TechStop WhatsApp Bot — environment variables
#  Copy to ".env" and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Claude API key (Anthropic) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_claude_api_key

# Your personal WhatsApp number (admin) — receives alerts & runs commands.
# Digits only or with +, any format. e.g. +923208512589
ADMIN_NUMBER=+923208512589

# Password for the read-only admin dashboard API (GET /api/customers?key=...)
ADMIN_DASHBOARD_PASSWORD=change-this-password

# Claude model (Haiku = fast + cheap, ideal for chat)
CLAUDE_MODEL=claude-haiku-4-5

# Server port (Railway sets this automatically — leave as-is)
PORT=8100

# CORS origin for the dashboard (your site, or * to allow all)
CORS_ORIGIN=*
